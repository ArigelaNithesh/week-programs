#include <iostream>
using namespace std;

class Student {
private:
    int rollNumber;
    string name;
    float marks;

public:
    // Default Constructor
    Student() {
        rollNumber = 0;
        name = "Unknown";
        marks = 0;
        cout << "Default Constructor called" << endl;
    }

    // Parameterized Constructor
    Student(int r, string n, float m) {
        rollNumber = r;
        name = n;
        marks = m;
        cout << "Constructor called for " << name << endl;
    }

    // Destructor
    ~Student() {
        cout << "Destructor called for " << name << endl;
    }

    // Function to set values
    void setData(int r, string n, float m) {
        rollNumber = r;
        name = n;
        marks = m;
    }

    // Function to display details
    void display() {
        cout << "Roll Number: " << rollNumber << endl;
        cout << "Name: " << name << endl;
        cout << "Marks: " << marks << endl;
    }
};

int main() {
    int n;

    cout << "Enter number of students: ";
    cin >> n;

    // Dynamically allocate array
    Student* students = new Student[n];

    // Input data
    for (int i = 0; i < n; i++) {
        int r;
        string name;
        float m;

        cout << "\nEnter details for student " << i + 1 << endl;
        cout << "Roll Number: ";
        cin >> r;
        cout << "Name: ";
        cin >> name;
        cout << "Marks: ";
        cin >> m;

        students[i].setData(r, name, m);
    }

    // Display data
    cout << "\nStudent Details:\n";
    for (int i = 0; i < n; i++) {
        cout << "\nStudent " << i + 1 << ":\n";
        students[i].display();
    }

    // Free memory
    delete[] students;

    return 0;
}
