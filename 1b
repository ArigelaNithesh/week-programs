#include <iostream>
using namespace std;

class Student {
private:
    int rollNumber;
    string name;
    float marks;

public:
    // Constructor
    Student(int r, string n, float m) {
        rollNumber = r;
        name = n;
        marks = m;
        cout << "Constructor called for " << name << endl;
    }

    // Destructor
    ~Student() {
        cout << "Destructor called for " << name << endl;
    }

    // Function to display details
    void display() {
        cout << "Roll Number: " << rollNumber << endl;
        cout << "Name: " << name << endl;
        cout << "Marks: " << marks << endl;
    }
};

int main() {
    // Creating objects
    Student s1(101, "Rahul", 85.5);
    Student s2(102, "Anita", 92.0);

    // Display details
    cout << "\nStudent 1 Details:" << endl;
    s1.display();

    cout << "\nStudent 2 Details:" << endl;
    s2.display();

    return 0;
}
