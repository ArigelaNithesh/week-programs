#include <iostream>
#include <string>
using namespace std;

// Function template to swap two variables
template <typename T>
void swapValues(T &a, T &b) {
    T temp = a;
    a = b;
    b = temp;
}

int main() {
    int x = 10, y = 20;
    float p = 5.5, q = 3.2;
    string s1 = "Hello", s2 = "World";

    // Swap integers
    cout << "Before swapping integers: x=" << x << ", y=" << y << endl;
    swapValues(x, y);
    cout << "After swapping integers: x=" << x << ", y=" << y << endl << endl;

    // Swap floats
    cout << "Before swapping floats: p=" << p << ", q=" << q << endl;
    swapValues(p, q);
    cout << "After swapping floats: p=" << p << ", q=" << q << endl << endl;

    // Swap strings
    cout << "Before swapping strings: s1=" << s1 << ", s2=" << s2 << endl;
    swapValues(s1, s2);
    cout << "After swapping strings: s1=" << s1 << ", s2=" << s2 << endl;

    return 0;
}
