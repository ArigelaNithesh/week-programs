#include <iostream>
#include <set>
using namespace std;

int main() {
    set<int> intSet;

    intSet.insert(50);
    intSet.insert(20);
    intSet.insert(30);
    intSet.insert(20); // duplicate ignored

    cout << "Set elements (sorted automatically): ";
    for (set<int>::iterator it = intSet.begin(); it != intSet.end(); ++it) {
        cout << *it << " ";
    }
    cout << endl;

    return 0;
}
